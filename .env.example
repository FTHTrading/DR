# ─── Database ────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://dics:changeme@localhost:5432/dics
POSTGRES_PASSWORD=changeme

# ─── Collector ────────────────────────────────────────────────────────────────
COLLECTOR_USER_AGENT=DICS-Collector/1.0 (+https://example.com/bot)
RESPECT_ROBOTS_TXT=true
FETCH_TIMEOUT_MS=15000
LOG_LEVEL=info

# ─── Extractor ────────────────────────────────────────────────────────────────
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
EXTRACTOR_POLL_SECONDS=30

# ─── Cloudflare Worker (alerts) ───────────────────────────────────────────────
# Set these with: wrangler secret put WEBHOOK_SECRET
# WEBHOOK_SECRET=replace-with-strong-random-secret
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/XXX/YYY/ZZZ
ALERT_THRESHOLD=0.65

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379
