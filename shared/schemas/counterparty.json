{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "dics/counterparty",
  "title": "Counterparty",
  "type": "object",
  "required": ["id", "project_id", "name", "role", "status"],
  "properties": {
    "id":          { "type": "string", "format": "uuid" },
    "project_id":  { "type": "string" },
    "name":        { "type": "string" },
    "role":        { "type": "string", "enum": ["offtaker", "epc", "dfi", "insurer", "regulator", "designer", "surveyor", "lender", "investor"] },
    "entity_type": { "type": ["string", "null"], "enum": ["government", "corporate", "multilateral", "ngo", "individual", null] },
    "status":      { "type": "string", "enum": ["identified", "engaged", "term_sheet", "contracted"] },
    "contact":     { "type": ["string", "null"] },
    "notes":       { "type": ["string", "null"] },
    "created_at":  { "type": "string", "format": "date-time" }
  }
}
