{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "dics/event",
  "title": "Event",
  "type": "object",
  "required": ["id", "doc_id", "type"],
  "properties": {
    "id":          { "type": "string", "format": "uuid" },
    "doc_id":      { "type": "string", "format": "uuid" },
    "type":        { "type": "string",
                     "enum": ["DiscoveryClaim","ConcessionAward","TenderRelease","CapexAnnouncement",
                              "Financing","RegulatoryChange","Partnership","ConstructionMilestone",
                              "OperationalLaunch"] },
    "description": { "type": "string" },
    "entity_ids":  { "type": "array", "items": { "type": "string", "format": "uuid" } },
    "raw_text":    { "type": "string" },
    "confidence":  { "type": "number", "minimum": 0, "maximum": 1 },
    "created_at":  { "type": "string", "format": "date-time" }
  }
}
